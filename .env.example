# Server-only — never commit real values

# Listen port (default 3011 — matches web NEXT_PUBLIC_SERVER_URL dev default)
PORT=3011
NODE_ENV=development

# Required for /api/data and /api/ai
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional alias for service role key
# SUPABASE_SERVICE_KEY=your-service-role-key

# Required for AI features (/api/ai/*)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional — comma-separated browser origins for production CORS
# CORS_ORIGINS=http://localhost:3000
